# Database Configuration
DATABASE__URL=mysql+aiomysql://nunzio:password@odysseus:3306/nunzio_workouts
DATABASE__POOL_SIZE=5
DATABASE__MAX_OVERFLOW=10
DATABASE__POOL_TIMEOUT=30

# LLM Configuration (OpenAI-compatible API)
LLM__BASE_URL=http://localhost:8080
# Or http://localhost:11434 for Ollama
LLM__MODEL=qwen3.5-27b
LLM__TIMEOUT=60

# Telegram Bot Configuration
TELEGRAM__TOKEN=your_telegram_bot_token_here
TELEGRAM__WEBHOOK_URL=
# Comma-separated Telegram user IDs allowed to use the bot (empty = no restriction)
# Message @userinfobot on Telegram to find your ID
TELEGRAM__ALLOWED_USER_IDS=[]

# Application Configuration
DEBUG=false
ENVIRONMENT=production

# Logging Configuration
LOGGING__LEVEL=INFO
LOGGING__FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s